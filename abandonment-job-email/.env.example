# Supabase (read-only access is sufficient)
SUPABASE_URL=https://ogvljockglpfnujpyvzh.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Brevo transactional email
BREVO_API_KEY=your-brevo-api-key
BREVO_TEMPLATE_ID=your-brevo-template-id

# Anthropic (match pitch generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App URLs used to build links in the email
STANDOUT_APP_URL=https://standout.jobs

# Safety switch: keep true until you are ready for live sends.
# When true: logs payloads, makes NO Brevo calls, does NOT write sent.json.
DRY_RUN=true
